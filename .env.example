# YouTube Data Pipeline — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# --- LLM API KEYS ---
# Required for summarization and model comparison.
# These names should match the environment variables in models.txt.

# OpenAI Key (e.g., for GPT models)
LLM_API_KEY=sk-your-openai-key-here

# Google AI Key (e.g., for Gemini/Gemma direct)
GOOGLE_API_KEY=your-google-ai-key-here

# OpenRouter Key (e.g., for Gemma via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# --- YOUTUBE DATA API ---
# Optional: helps with title/view count metadata
YOUTUBE_API_KEY=your-youtube-data-api-key-here
