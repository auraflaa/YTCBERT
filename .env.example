# YouTube Data Pipeline — Environment Variables
# Copy this file to .env and fill in your keys.
# NEVER commit .env to version control.

# Required for LLM comment summarization
LLM_API_KEY=sk-your-api-key-here

# Optional — enables pre-fetch estimates (title, view count, comment count, ETA)
# Get a free key: https://console.cloud.google.com/ -> Enable YouTube Data API v3
YOUTUBE_API_KEY=your-youtube-data-api-key-here
